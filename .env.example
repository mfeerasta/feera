# =====================================================================
# Feera environment template
# Copy to .env.local at repo root and per-app as needed.
# NEVER commit a populated .env file. Real secrets live in Doppler.
# =====================================================================

# --- Core ---
NODE_ENV=development

# --- Supabase (production region: eu-central-1 / Frankfurt) ---
# Provision via Vercel integration or Supabase dashboard before filling.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_PROJECT_REF=
SUPABASE_DB_URL=
SUPABASE_DB_URL_POOLED=

# --- Auth ---
AUTH_SECRET=

# --- Twilio (OTP + WhatsApp + SMS) ---
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_VERIFY_SERVICE_SID=
TWILIO_WHATSAPP_FROM=
TWILIO_SMS_FROM=

# --- Payments ---
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=

JAZZCASH_MERCHANT_ID=
JAZZCASH_PASSWORD=
JAZZCASH_INTEGRITY_SALT=
JAZZCASH_API_BASE=

EASYPAISA_STORE_ID=
EASYPAISA_HASH_KEY=
EASYPAISA_API_BASE=

RAAST_1LINK_API_KEY=
RAAST_MERCHANT_ID=

# --- Email / Push ---
RESEND_API_KEY=
ONESIGNAL_APP_ID=
ONESIGNAL_REST_API_KEY=

# --- Observability ---
SENTRY_DSN=
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_AUTH_TOKEN=
SENTRY_ORG=
SENTRY_PROJECT=

POSTHOG_PROJECT_API_KEY=
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=

# --- Maps ---
NEXT_PUBLIC_MAPBOX_TOKEN=
GOOGLE_MAPS_API_KEY=

# --- Cache / Rate limit ---
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# --- Edition ---
EDITION_INVITE_CODE_SALT=
