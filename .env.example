# =====================================================================
# Feera environment template
# Copy to .env.local at repo root and per-app as needed.
# NEVER commit a populated .env file.
# =====================================================================

# --- Core ---
NODE_ENV=development
APP_URL=http://localhost:3000

# --- Neon Postgres (target region: aws-eu-central-1 / Frankfurt) ---
# Use POOLED for the app process. Use direct for migrations and admin tools.
NEON_PROJECT_ID=
NEON_API_KEY=
DATABASE_URL=
DATABASE_URL_POOLED=

# --- better-auth ---
AUTH_SECRET=
AUTH_URL=http://localhost:3000

# --- Twilio Verify (phone + WhatsApp OTP) ---
# Verify Service for OTPs, plus Messaging API for transactional sends (notifications).
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_VERIFY_SERVICE_SID=
TWILIO_WHATSAPP_FROM=
TWILIO_SMS_FROM=
# Optional. When set, the SMS channel routes via the Messaging Service Copilot
# (preferred for sender-pool + opt-out compliance) instead of TWILIO_SMS_FROM.
TWILIO_MESSAGING_SERVICE_SID=

# --- OAuth (better-auth providers) ---
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
APPLE_CLIENT_ID=
APPLE_CLIENT_SECRET=
APPLE_KEY_ID=
APPLE_TEAM_ID=

# --- Email ---
RESEND_API_KEY=
EMAIL_FROM="Feera <hello@feera.ai>"
# Optional. Reserved for future Resend reply-to / domain routing.
RESEND_FROM_DOMAIN=feera.ai

# --- Payments ---
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=

JAZZCASH_MERCHANT_ID=
JAZZCASH_PASSWORD=
JAZZCASH_INTEGRITY_SALT=
JAZZCASH_API_BASE=

EASYPAISA_STORE_ID=
EASYPAISA_HASH_KEY=
EASYPAISA_API_BASE=

RAAST_1LINK_API_KEY=
RAAST_MERCHANT_ID=

# --- Realtime (Soketi self-hosted) ---
NEXT_PUBLIC_SOKETI_HOST=realtime.feera.ai
NEXT_PUBLIC_SOKETI_PORT=443
NEXT_PUBLIC_SOKETI_KEY=
SOKETI_APP_ID=
SOKETI_KEY=
SOKETI_SECRET=

# --- Storage (Hetzner Object Storage, S3-compatible) ---
S3_ENDPOINT=https://fsn1.your-objectstorage.com
S3_REGION=fsn1
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_BUCKET_PUBLIC=feera-public
S3_BUCKET_PRIVATE=feera-user-private
S3_BUCKET_EDITION=feera-edition
NEXT_PUBLIC_CDN_URL=https://cdn.feera.ai

# --- Push notifications ---
EXPO_ACCESS_TOKEN=
ONESIGNAL_APP_ID=
ONESIGNAL_REST_API_KEY=

# --- Observability ---
SENTRY_DSN=
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_AUTH_TOKEN=
SENTRY_ORG=
SENTRY_PROJECT=

POSTHOG_PROJECT_API_KEY=
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://posthog.feera.ai

# --- Maps ---
NEXT_PUBLIC_MAPBOX_TOKEN=
GOOGLE_MAPS_API_KEY=

# --- Cache / rate limit ---
REDIS_URL=redis://localhost:6379

# --- Edition ---
EDITION_INVITE_CODE_SALT=

# --- PII encryption (pgcrypto) ---
# 32-byte random base64. Generate with: openssl rand -base64 32
# Rotate quarterly; move CURRENT to PREV during the rotation window.
PII_ENCRYPTION_KEY_CURRENT=
PII_ENCRYPTION_KEY_PREV=

# --- Two-factor auth (M8 polish) ---
TOTP_ISSUER=Feera
TOTP_BACKUP_CODE_COUNT=10
TOTP_REQUIRED_ROLES=club_staff,platform_admin

# --- A11y CI ---
A11Y_TARGET_URL=https://www.feera.ai

# --- Deploy ---
DEPLOY_SSH_HOST=46.225.157.75
DEPLOY_SSH_USER=root
GHCR_PUBLISH_TOKEN=
