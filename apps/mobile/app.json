{
  "expo": {
    "name": "Feera",
    "slug": "feera",
    "scheme": "feera",
    "version": "0.1.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#FAF8F4"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "ai.feera.app"
    },
    "android": {
      "package": "ai.feera.app",
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#FAF8F4"
      }
    },
    "plugins": ["expo-router", "expo-font", "expo-localization"],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "eas": {
        "projectId": ""
      }
    }
  }
}
