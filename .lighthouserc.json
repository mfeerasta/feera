{
  "ci": {
    "collect": {
      "url": [
        "https://www.feera.ai/",
        "https://www.feera.ai/play",
        "https://www.feera.ai/play/clubs",
        "https://www.feera.ai/sign-in",
        "https://www.feera.ai/edition"
      ],
      "numberOfRuns": 1,
      "settings": {
        "preset": "desktop",
        "skipAudits": ["uses-http2"]
      }
    },
    "assert": {
      "assertions": {
        "categories:performance": ["error", { "minScore": 0.85 }],
        "categories:accessibility": ["error", { "minScore": 0.95 }],
        "categories:best-practices": ["error", { "minScore": 0.9 }],
        "categories:seo": ["error", { "minScore": 0.9 }]
      }
    },
    "upload": {
      "target": "filesystem",
      "outputDir": ".lighthouseci"
    }
  }
}
